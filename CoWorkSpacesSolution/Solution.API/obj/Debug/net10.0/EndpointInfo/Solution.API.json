  "paths": {
    "/api/Espacios": {
      "get": {
        "tags": [
          "Espacios"
        ],
        "summary": "Obtiene la lista de todos los espacios de CoWorking que se encuentran activos en el sistema.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EspacioDtoIEnumerableResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponseDto"
                }
              }
            }
          }
        }
      }
    },
